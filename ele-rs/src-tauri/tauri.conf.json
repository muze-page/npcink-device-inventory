{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Npcink Device Agent",
  "version": "0.2.0",
  "identifier": "ink.npc.npcink-device-agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Npcink Device Agent",
        "label": "main",
        "width": 1120,
        "height": 720,
        "minWidth": 980,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://github.com; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["nsis", "dmg", "app"],
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Device collection and upload tool",
    "longDescription": "Collects local hardware and runtime information and submits it to Npcink Device Inventory.",
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYwRERFNTEwODdCMjQyODAKUldTQVFyS0hFT1hkWUk2QzU5RXF2clNIZ2VHY3ZXbzArZUFKZitxSzNtNHVSV0c1dmV3Rkx5TG0K",
      "endpoints": [
        "https://github.com/muze-page/npcink-device-inventory/releases/latest/download/latest.json"
      ]
    }
  }
}
