{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Npcink Device Agent",
  "version": "0.1.2",
  "identifier": "ink.npc.npcink-device-agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Npcink Device Agent",
        "label": "main",
        "width": 1120,
        "height": 720,
        "minWidth": 980,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "category": "Utility",
    "shortDescription": "Device collection and upload tool",
    "longDescription": "Collects local hardware and runtime information and submits it to Npcink Device Inventory.",
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    }
  }
}
