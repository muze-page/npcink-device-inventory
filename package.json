{
  "name": "npcink-device-inventory-release-tools",
  "private": true,
  "type": "module",
  "scripts": {
    "build:release": "node scripts/build-release-package.mjs",
    "build:submission": "node scripts/build-release-package.mjs --submission",
    "check:backup-restore": "php tests/backup-restore-fixtures.php",
    "check:asset-search": "php tests/asset-search-fixtures.php",
    "check:asset-writes": "php tests/asset-write-fixtures.php",
    "check:device-upload": "php tests/device-upload-boundary-fixtures.php",
    "check:schema-migrations": "php tests/schema-migration-fixtures.php",
    "check:identity": "php tests/identity-contract-fixtures.php && php tests/identity-claim-fixtures.php && php tests/observation-ingest-fixtures.php",
    "check:fixtures": "npm run check:backup-restore && npm run check:asset-search && npm run check:asset-writes && npm run check:device-upload && npm run check:schema-migrations && npm run check:identity",
    "check:versions": "node scripts/check-version-contract.mjs",
    "check:desktop-quality": "node scripts/check-desktop-quality.mjs",
    "check:release-scope": "node scripts/check-release-scope.mjs",
    "check:desktop-manifests": "node scripts/check-desktop-update-manifests.mjs",
    "check:desktop-update-transition": "node scripts/check-desktop-update-transition.mjs",
    "check:wporg-review": "node scripts/check-wordpress-org-review-rules.mjs release/npcink-device-inventory.zip",
    "check:package": "node scripts/check-release-package.mjs release/npcink-device-inventory.zip && npm run check:wporg-review",
    "check:release": "node scripts/check-release-readiness.mjs",
    "check:submission": "node scripts/check-release-readiness.mjs --submission"
  }
}
